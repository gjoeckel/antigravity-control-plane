{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/a00288946",
        "/Users/a00288946/Projects",
        "/Users/a00288946/Agents",
        "/Users/a00288946/Projects/github-globals/antigravity",
        "/Users/a00288946/Agents/resources/github-globals/antigravity"
      ],
      "env": {
        "ALLOWED_PATHS": "*",
        "READ_ONLY": "false"
      }
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "github-minimal": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-github-minimal"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "shell-minimal": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-shell-minimal"
      ],
      "env": {
        "WORKING_DIRECTORY": "/Users/a00288946",
        "ALLOWED_COMMANDS": "npm,git,node,php,composer,curl,wget,ls,cat,grep,find,chmod,chown,mkdir,rm,cp,mv,pwd,echo,which"
      }
    },
    "playwright-minimal": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-playwright-minimal"
      ]
    },
    "agent-autonomy": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-agent-autonomy"
      ]
    },
    "gas-fakes": {
      "command": "npx",
      "args": [
        "-y",
        "@mcpher/gas-fakes-mcp"
      ],
      "type": "stdio"
    }
  }
}
