rules_version = '2';

service cloud.firestore {
match /databases/{database}/documents {

// Antigravity Bridge Rules
// Matches the structure: /artifacts/{appId}/public/data/{collectionName}/{docId}
match /artifacts/{appId}/public/data/{collection}/{document} {
  allow read, write: if request.auth != null;
}

// Matches the structure: /artifacts/{appId}/users/{userId}/{collectionName}/{docId}
match /artifacts/{appId}/users/{userId}/{collection}/{document} {
  allow read, write: if request.auth != null && request.auth.uid == userId;
}

// Default deny for all other paths to maintain gravity stability
match /{document=**} {
  allow read, write: if false;
}


}
}